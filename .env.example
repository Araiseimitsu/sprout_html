# Docker Compose 用の環境変数サンプル。
# このファイルをプロジェクトルートの .env にコピーして設定してください。

# 編集対象 HTML を置く Windows ホスト側ディレクトリ。
# Docker コンテナ内では /workspace/html としてマウントされます。
SPROUT_HOST_ROOT=C:\path\to\html-root

# 社内 LAN で公開する HTTP ポート。
SPROUT_HTTP_PORT=80

# FastAPI を直接別オリジンから呼ぶ場合のみ追加します。
# 通常の Docker 構成では Nginx 同一オリジン経由なので既定値で十分です。
CORS_ORIGINS=http://localhost
