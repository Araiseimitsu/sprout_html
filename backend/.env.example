# Sprout HTML backend 環境変数サンプル
# このファイルを .env としてコピーし、値を設定してください(.env は .gitignore 済み)。

# ファイルピッカーの初期表示ディレクトリ(未指定時はホームディレクトリ)。
# SPROUT_ROOT=/path/to/your/html/projects
# Docker Compose では docker-compose.yml 側で /workspace/html が設定されます。
# Windows ホスト側の実ディレクトリはプロジェクトルート .env の SPROUT_HOST_ROOT に設定してください。

# ---- AI(Gemini)関連 ----
# 必須: Google AI Studio で取得した API キー。
GEMINI_API_KEY=

# AIモードの既定モデルID(任意)。選択肢は gemini-3.1-flash-lite / gemini-3.5-flash です。
# 例: GEMINI_TEXT_MODEL=gemini-3.1-flash-lite / GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# 生成画像をファイル保存する際のサブディレクトリ名(任意)。
SPROUT_IMAGE_DIR=sprout-images
